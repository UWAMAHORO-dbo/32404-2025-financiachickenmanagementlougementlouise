            const queries = `-- ============================================================
-- 1. Simple CTE: Total sales per customer
-- ============================================================
WITH customer_sales AS (
    SELECT 
        c.customer_name,
        SUM(s.total_amount) AS total_spent
    FROM customers c
    JOIN egg_sales s ON c.customer_id = s.customer_id
    GROUP BY c.customer_id
)
SELECT * FROM customer_sales ORDER BY total_spent DESC;

-- ============================================================
-- 2. Multi-CTE: Monthly Profit (MySQL-compatible using UNION)
-- ============================================================
WITH monthly_revenue AS (
    SELECT 
        DATE_FORMAT(sale_date, '%Y-%m') AS month,
        SUM(total_amount) AS revenue
    FROM egg_sales
    GROUP BY month
),
monthly_expenses AS (
    SELECT 
        DATE_FORMAT(expense_date, '%Y-%m') AS month,
        SUM(amount) AS expenses
    FROM expenses
    GROUP BY month
)
SELECT 
    COALESCE(r.month, e.month) AS month,
    COALESCE(r.revenue, 0) AS revenue,
    COALESCE(e.expenses, 0) AS expenses,
    COALESCE(r.revenue, 0) - COALESCE(e.expenses, 0) AS profit
FROM monthly_revenue r
LEFT JOIN monthly_expenses e ON r.month = e.month
UNION
SELECT 
    COALESCE(r.month, e.month) AS month,
    COALESCE(r.revenue, 0) AS revenue,
    COALESCE(e.expenses, 0) AS expenses,
    COALESCE(r.revenue, 0) - COALESCE(e.expenses, 0) AS profit
FROM monthly_revenue r
RIGHT JOIN monthly_expenses e ON r.month = e.month
WHERE r.month IS NULL;

-- ============================================================
-- 3. Window Functions
-- ============================================================
-- 3a. Rank customers by total sales
SELECT 
    c.customer_name,
    SUM(s.total_amount) AS total_spent,
    RANK() OVER (ORDER BY SUM(s.total_amount) DESC) AS rank_order,
    DENSE_RANK() OVER (ORDER BY SUM(s.total_amount) DESC) AS dense_rank,
    ROW_NUMBER() OVER (ORDER BY SUM(s.total_amount) DESC) AS row_num
FROM customers c
JOIN egg_sales s ON c.customer_id = s.customer_id
GROUP BY c.customer_id;

-- 3b. Running total of sales per customer (by date)
SELECT 
    s.sale_date,
    c.customer_name,
    s.total_amount,
    SUM(s.total_amount) OVER (PARTITION BY c.customer_id ORDER BY s.sale_date) AS running_total
FROM egg_sales s
JOIN customers c ON s.customer_id = c.customer_id
ORDER BY c.customer_id, s.sale_date;

-- ============================================================
-- 4. Bonus: Cost per Sale (direct costs only)
-- ============================================================
SELECT 
    s.sale_id,
    s.sale_date,
    c.customer_name,
    s.total_amount AS revenue,
    COALESCE(SUM(e.amount), 0) AS direct_costs,
    s.total_amount - COALESCE(SUM(e.amount), 0) AS margin
FROM egg_sales s
LEFT JOIN expenses e ON s.sale_id = e.sale_id
JOIN customers c ON s.customer_id = c.customer_id
GROUP BY s.sale_id
ORDER BY s.sale_date;`;

